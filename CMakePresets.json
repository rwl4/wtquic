{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (RelWithDebInfo, tests)",
            "binaryDir": "${sourceDir}/build/default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "WTQ_BUILD_TESTS": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "shared",
            "displayName": "Shared library (symbol policy)",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/shared",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "asan",
            "displayName": "ASan + UBSan",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-sanitize-recover=undefined -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined -fno-sanitize-recover=undefined"
            }
        },
        {
            "name": "fuzz",
            "displayName": "libFuzzer targets (runtime required)",
            "binaryDir": "${sourceDir}/build/fuzz-check",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "WTQ_BUILD_FUZZ": "ON",
                "WTQ_REQUIRE_FUZZ": "ON",
                "WTQ_BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "ios-device",
            "displayName": "iOS device cross-build (arm64, core + network, no tests)",
            "binaryDir": "${sourceDir}/build/ios-device",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_SYSROOT": "iphoneos",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "16.0",
                "WTQ_BUILD_TESTS": "OFF",
                "WTQ_BUILD_MSQUIC": "OFF",
                "WTQ_BUILD_NETWORK": "ON"
            }
        },
        {
            "name": "ios-sim",
            "displayName": "iOS sim cross-build (arm64, core + network, no tests)",
            "binaryDir": "${sourceDir}/build/ios-sim",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_SYSROOT": "iphonesimulator",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "16.0",
                "WTQ_BUILD_TESTS": "OFF",
                "WTQ_BUILD_MSQUIC": "OFF",
                "WTQ_BUILD_NETWORK": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "shared",
            "configurePreset": "shared"
        },
        {
            "name": "asan",
            "configurePreset": "asan"
        },
        {
            "name": "fuzz",
            "configurePreset": "fuzz"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        },
        {
            "name": "asan",
            "configurePreset": "asan",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        },
        {
            "name": "shared",
            "configurePreset": "shared",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        },
        {
            "name": "fuzz",
            "configurePreset": "fuzz",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        }
    ]
}
